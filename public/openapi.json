{
  "openapi": "3.0.3",
  "info": {
    "title": "URGE v2 API",
    "description": "Prompt registry and version control API. Manage prompts, versions, render templates, and store LLM results.",
    "version": "2.0.0"
  },
  "servers": [
    {
      "url": "{baseUrl}/api/v1",
      "variables": {
        "baseUrl": {
          "default": "https://urge-next.acordado.org"
        }
      }
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "API key with 'urge_' prefix"
      }
    },
    "schemas": {
      "Prompt": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "slug": { "type": "string" },
          "type": { "type": "string", "enum": ["prompt", "fragment"] },
          "description": { "type": "string", "nullable": true },
          "category_id": { "type": "integer", "nullable": true },
          "tags": { "type": "array", "items": { "type": "string" }, "nullable": true },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "PromptVersion": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "prompt_id": { "type": "integer" },
          "version_number": { "type": "integer" },
          "content": { "type": "string" },
          "commit_message": { "type": "string", "nullable": true },
          "variables": { "type": "array", "items": { "type": "string" } },
          "variable_metadata": { "type": "object", "nullable": true },
          "includes": { "type": "array", "items": { "type": "string" }, "nullable": true },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "Result": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "prompt_id": { "type": "integer" },
          "prompt_version_id": { "type": "integer" },
          "source": { "type": "string", "enum": ["api", "manual", "import", "mcp"] },
          "provider_name": { "type": "string", "nullable": true },
          "model_name": { "type": "string", "nullable": true },
          "response_text": { "type": "string" },
          "notes": { "type": "string", "nullable": true },
          "rating": { "type": "integer", "minimum": 1, "maximum": 5, "nullable": true },
          "starred": { "type": "boolean" },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "RenderResult": {
        "type": "object",
        "properties": {
          "rendered": { "type": "string" },
          "variables_used": { "type": "array", "items": { "type": "string" } },
          "variables_missing": { "type": "array", "items": { "type": "string" } },
          "includes_resolved": { "type": "array", "items": { "type": "string" } },
          "prompt": { "type": "string" },
          "version": { "type": "integer" }
        }
      },
      "PaginationMeta": {
        "type": "object",
        "properties": {
          "current_page": { "type": "integer" },
          "last_page": { "type": "integer" },
          "per_page": { "type": "integer" },
          "total": { "type": "integer" }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": { "type": "string" }
        }
      }
    }
  },
  "paths": {
    "/health": {
      "get": {
        "summary": "Health check",
        "security": [],
        "responses": {
          "200": {
            "description": "Server status",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string" },
                    "version": { "type": "string" },
                    "timestamp": { "type": "string", "format": "date-time" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/prompts": {
      "get": {
        "summary": "List prompts",
        "parameters": [
          { "name": "type", "in": "query", "schema": { "type": "string", "enum": ["prompt", "fragment"] } },
          { "name": "category_id", "in": "query", "schema": { "type": "integer" } },
          { "name": "tag", "in": "query", "schema": { "type": "string" } },
          { "name": "search", "in": "query", "schema": { "type": "string" } },
          { "name": "per_page", "in": "query", "schema": { "type": "integer", "default": 20 } },
          { "name": "page", "in": "query", "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of prompts",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": { "type": "array", "items": { "$ref": "#/components/schemas/Prompt" } },
                    "meta": { "$ref": "#/components/schemas/PaginationMeta" }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create a prompt",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name"],
                "properties": {
                  "name": { "type": "string" },
                  "type": { "type": "string", "enum": ["prompt", "fragment"], "default": "prompt" },
                  "description": { "type": "string" },
                  "category_id": { "type": "integer" },
                  "tags": { "type": "array", "items": { "type": "string" } }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created prompt",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": { "$ref": "#/components/schemas/Prompt" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/prompts/{slug}": {
      "get": {
        "summary": "Get a prompt",
        "parameters": [
          { "name": "slug", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Prompt with active version and counts",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": { "$ref": "#/components/schemas/Prompt" }
                  }
                }
              }
            }
          }
        }
      },
      "patch": {
        "summary": "Update a prompt",
        "parameters": [
          { "name": "slug", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "type": { "type": "string", "enum": ["prompt", "fragment"] },
                  "description": { "type": "string" },
                  "category_id": { "type": "integer" },
                  "tags": { "type": "array", "items": { "type": "string" } }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated prompt"
          }
        }
      }
    },
    "/prompts/{slug}/versions": {
      "get": {
        "summary": "List versions",
        "parameters": [
          { "name": "slug", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Paginated versions"
          }
        }
      },
      "post": {
        "summary": "Create a version",
        "parameters": [
          { "name": "slug", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["content"],
                "properties": {
                  "content": { "type": "string" },
                  "commit_message": { "type": "string" },
                  "variable_metadata": { "type": "object" }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created version",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": { "$ref": "#/components/schemas/PromptVersion" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/prompts/{slug}/versions/{version}": {
      "get": {
        "summary": "Get a version",
        "parameters": [
          { "name": "slug", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "version", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "Version details"
          }
        }
      }
    },
    "/prompts/{slug}/render": {
      "post": {
        "summary": "Render a prompt template",
        "parameters": [
          { "name": "slug", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "version": { "type": "integer" },
                  "variables": { "type": "object", "additionalProperties": { "type": "string" } }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Rendered template",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": { "$ref": "#/components/schemas/RenderResult" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/prompts/{slug}/results": {
      "get": {
        "summary": "List results for a prompt",
        "parameters": [
          { "name": "slug", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "version", "in": "query", "schema": { "type": "integer" } },
          { "name": "starred", "in": "query", "schema": { "type": "boolean" } }
        ],
        "responses": {
          "200": {
            "description": "Paginated results"
          }
        }
      },
      "post": {
        "summary": "Create a result",
        "parameters": [
          { "name": "slug", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["version", "response_text"],
                "properties": {
                  "version": { "type": "integer" },
                  "response_text": { "type": "string" },
                  "source": { "type": "string", "enum": ["api", "manual", "import", "mcp"], "default": "api" },
                  "provider_name": { "type": "string" },
                  "model_name": { "type": "string" },
                  "notes": { "type": "string" },
                  "rating": { "type": "integer", "minimum": 1, "maximum": 5 },
                  "starred": { "type": "boolean" },
                  "rendered_content": { "type": "string" },
                  "variables_used": { "type": "object" }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created result"
          }
        }
      }
    },
    "/results/{id}": {
      "get": {
        "summary": "Get a result",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "Result details"
          }
        }
      },
      "patch": {
        "summary": "Update a result (rating, starred, notes)",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "rating": { "type": "integer", "minimum": 1, "maximum": 5 },
                  "starred": { "type": "boolean" },
                  "notes": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated result"
          }
        }
      }
    },
    "/mcp": {
      "post": {
        "summary": "MCP JSON-RPC endpoint",
        "description": "Send MCP protocol JSON-RPC 2.0 requests. Supports: initialize, tools/list, tools/call, resources/list, resources/read.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["jsonrpc", "method"],
                "properties": {
                  "jsonrpc": { "type": "string", "enum": ["2.0"] },
                  "id": { "type": "string" },
                  "method": { "type": "string" },
                  "params": { "type": "object" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "JSON-RPC response"
          }
        }
      },
      "get": {
        "summary": "MCP SSE stream",
        "description": "Server-Sent Events endpoint for MCP protocol.",
        "responses": {
          "200": {
            "description": "SSE stream",
            "content": {
              "text/event-stream": {}
            }
          }
        }
      }
    }
  }
}
